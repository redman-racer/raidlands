{
  "name": "raidlands-website",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "monuments:catalog": "tsx scripts/index-rustrelay-assets.ts",
    "monuments:catalog:check": "tsx scripts/index-rustrelay-assets.ts --check",
    "monuments:lod": "tsx scripts/generate-monument-lods.ts",
    "monuments:lod:parallel": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-monument-lods-parallel.ps1",
    "monuments:lod:check": "tsx scripts/generate-monument-lods.ts --check",
    "monuments:lod:preview": "tsx scripts/render-monument-preview.ts",
    "monuments:lod:review": "tsx scripts/render-monument-contact-sheets.ts",
    "monuments:lod:approve": "tsx scripts/review-monument-lod.ts",
    "trees:lod": "tsx scripts/generate-tree-lods.ts",
    "trees:lod:check": "tsx scripts/generate-tree-lods.ts --check",
    "compiler": "tsx assets/ts/airstrike-animation-editor/cli.ts",
    "fixtures:update": "tsx assets/ts/airstrike-animation-editor/cli.ts fixtures tests/fixtures/airstrike-animations --update",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.3.0",
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/extensions": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "@types/node": "^24.0.0",
    "@types/three": "^0.166.0",
    "draco3dgltf": "^1.5.7",
    "meshoptimizer": "^0.18.1",
    "sharp": "^0.34.5",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "three": "^0.166.1"
  }
}
