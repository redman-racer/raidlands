Options -Indexes
DirectoryIndex index.php index.html

SetEnvIf Authorization "(.+)" HTTP_AUTHORIZATION=$1

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^store/item/([^/]+)/?$ store/item/index.php?item=$1 [L,QSA]
  RewriteRule ^store/kit/([^/]+)/?$ store/kit/index.php?kit=$1 [L,QSA]
</IfModule>

<FilesMatch "^\.env">
  Require all denied
</FilesMatch>

<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
  AddType model/gltf-binary .glb
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE application/javascript text/javascript application/json application/manifest+json
  SetEnvIfNoCase Request_URI "\.(?:glb|webp|hdr)$" no-gzip dont-vary
</IfModule>

<IfModule mod_headers.c>
  # Vite content-hashed chunks are safe to retain permanently. A changed build
  # gets a new filename, so repeat visits reuse Three.js without revalidation.
  <FilesMatch "-[A-Za-z0-9_-]{8}\.(?:js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Stable 3D media URLs may be replaced in-place, so keep a bounded cache.
  <FilesMatch "\.(?:glb|webp|hdr)$">
    Header set Cache-Control "public, max-age=604800, stale-while-revalidate=86400"
  </FilesMatch>
</IfModule>
