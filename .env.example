# Copy this file to .env at the project root and fill in environment-specific values.
# Keep .env private. It is ignored by Git.

RAIDLANDS_SERVER_NAME="Raidlands 1000x"
RAIDLANDS_TAGLINE="Raid. Respawn. Rebuild. Repeat."
RAIDLANDS_REGION="US Central"
RAIDLANDS_MAP_NAME="Procedural Battlefield"
RAIDLANDS_SERVER_FPS="Stable"
RAIDLANDS_SERVER_QUEUE=0
RAIDLANDS_PLAYERS_ONLINE=127
RAIDLANDS_MAX_PLAYERS=250
RAIDLANDS_SERVER_ONLINE=true
RAIDLANDS_SERVER_STATS_PROVIDER=raidlands
RAIDLANDS_SERVER_STATUS_CACHE_SECONDS=60
RAIDLANDS_SERVER_STATUS_STALE_SECONDS=90
RAIDLANDS_SERVER_STATUS_SAMPLE_RETENTION_DAYS=30
RAIDLANDS_SERVER_STATUS_HOURLY_RETENTION_MONTHS=24
RAIDLANDS_CONNECT_COMMAND="connect raidlands.net:25607"
RAIDLANDS_STEAM_CONNECT_URL="steam://connect/raidlands.net:25607"
RAIDLANDS_DISCORD_INVITE_URL="https://discord.gg/N6wnHzMhWS"
RAIDLANDS_WIPE_DAYS=4
RAIDLANDS_WIPE_DAY_NAMES=Thursday
RAIDLANDS_WIPE_TIME=19:00
RAIDLANDS_WIPE_TIMEZONE=Europe/London
RAIDLANDS_AUTH_STEAM_URL=
RAIDLANDS_AUTH_DISCORD_URL=

# Setup fallback only. After database/migrations/007_admin_auth.sql is installed,
# approved admins sign in with Steam IDs stored in admin_users/admin_user_roles.
RAIDLANDS_ADMIN_USERNAME=admin
RAIDLANDS_ADMIN_PASSWORD=change-me
RAIDLANDS_ADMIN_PASSWORD_HASH=
RAIDLANDS_ADMIN_SESSION_KEY=raidlands_admin_authenticated

RAIDLANDS_DB_DSN="mysql:host=localhost;dbname=raiduonz_website"
RAIDLANDS_DB_USER=raiduonz_user
RAIDLANDS_DB_PASSWORD=change-this-password

RAIDLANDS_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
RAIDLANDS_STRIPE_SECRET_KEY=sk_test_replace_me
RAIDLANDS_STRIPE_WEBHOOK_SECRET=whsec_replace_me

RAIDLANDS_STEAM_API_KEY=
RAIDLANDS_STEAM_API_BASE_URL="https://api.steampowered.com"
RAIDLANDS_STEAM_API_CACHE_SECONDS=86400

RAIDLANDS_BRIDGE_SERVER_ID=raidlands-main
RAIDLANDS_BRIDGE_SHARED_SECRET=replace-with-a-long-random-secret
RAIDLANDS_BRIDGE_HMAC_SKEW_SECONDS=300
RAIDLANDS_BRIDGE_MANAGED_GROUPS=vip_bronze,vip_gold,vip_elite,perk_personal_mini,perk_skinbox,perk_raid_kit,perk_queue_priority,perk_supporter_badge,perk_pvp_light,perk_pvp_rifle,perk_pvp_roamer,perk_pvp_heavy,perk_pvp_elite,perk_pvp_breach

RAIDLANDS_CLAN_API_RATE_LIMIT_PER_MINUTE=60
RAIDLANDS_CLAN_API_KEY_LIMIT_PER_PLAYER=5
